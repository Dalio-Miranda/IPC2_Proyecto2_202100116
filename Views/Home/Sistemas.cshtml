@using SistemaDrones.TDAs
@using SistemaDrones.Modelos
@{
    ViewData["Title"] = "Sistemas de Drones";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var sistemas = ViewBag.Sistemas as ListaEnlazada<SistemaDronesModelo>;
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-grid"></i> Sistemas de Drones</h5>
        <span class="badge bg-warning text-dark">@(sistemas?.Tamanio ?? 0) sistemas</span>
    </div>
    <div class="card-body">
        @if (sistemas == null || sistemas.EstaVacia)
        {
            <p class="text-muted text-center py-3">
                <i class="bi bi-inbox"></i> No hay sistemas de drones registrados. Carga un XML de entrada primero.
            </p>
        }
        else
        {
            @for (int i = 0; i < sistemas.Tamanio; i++)
            {
                var sistema = sistemas.Obtener(i);
                <div class="card mb-4">
                    <div class="card-header">
                        <h6 class="mb-0">
                            <i class="bi bi-diagram-3"></i> @sistema.Nombre
                            <span class="badge bg-secondary ms-2">Altura máx: @sistema.AlturaMaxima mts</span>
                            <span class="badge bg-info text-dark ms-1">@sistema.CantidadDrones drones</span>
                        </h6>
                    </div>
                    <div class="card-body table-responsive">
                        <table class="table table-bordered text-center">
                            <thead>
                                <tr>
                                    <th>Altura (mts)</th>
                                    @{
                                        var nodoDron = sistema.Contenido.ObtenerCabeza();
                                        while (nodoDron != null)
                                        {
                                            <th>@nodoDron.Dato.NombreDron</th>
                                            nodoDron = nodoDron.Siguiente;
                                        }
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @for (int h = sistema.AlturaMaxima; h >= 1; h--)
                                {
                                    <tr>
                                        <td><strong>@h</strong></td>
                                        @{
                                            var nodo = sistema.Contenido.ObtenerCabeza();
                                            while (nodo != null)
                                            {
                                                var letra = sistema.ObtenerLetra(nodo.Dato.NombreDron, h);
                                                <td>@(letra ?? "-")</td>
                                                nodo = nodo.Siguiente;
                                            }
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    </div>
</div>
