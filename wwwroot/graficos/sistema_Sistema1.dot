digraph SistemaDrones {
  rankdir=TB;
  node [shape=record, style=filled, fillcolor="#1f2937", fontcolor="white", fontname="Arial", color="#374151"];
  graph [bgcolor="#111827", fontcolor="white", fontname="Arial"];
  edge [color="#6b7280"];
  label="Sistema: Sistema1\nAltura máxima: 7 mts | Drones: 3";
  labelloc=t;
  fontsize=16;
  fontcolor="#60a5fa";
  header [label="{Altura|DronX|DronY|DronZ}", fillcolor="#1e3a5f", fontcolor="#60a5fa"];
  altura7 [label="{7|K|N|Q}"];
  altura6 [label="{6|J|M|P}"];
  altura5 [label="{5|I|L|O}"];
  altura4 [label="{4|F|G|H}"];
  altura3 [label="{3|D|P|E}"];
  altura2 [label="{2|I|C|C}"];
  altura1 [label="{1|A|2|B}"];
  header -> altura7 -> altura6 -> altura5 -> altura4 -> altura3 -> altura2 -> altura1;
}
