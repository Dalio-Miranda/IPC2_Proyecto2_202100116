digraph SistemaDrones {
  rankdir=TB;
  node [shape=record, style=filled, fillcolor="#1f2937", fontcolor="white", fontname="Arial", color="#374151"];
  graph [bgcolor="#111827", fontcolor="white", fontname="Arial"];
  edge [color="#6b7280"];
  label="Sistema: SistemaFacil\nAltura máxima: 5 mts | Drones: 3";
  labelloc=t;
  fontsize=16;
  fontcolor="#60a5fa";
  header [label="{Altura|Alpha|Beta|Gamma}", fillcolor="#1e3a5f", fontcolor="#60a5fa"];
  altura5 [label="{5|S|O|L}"];
  altura4 [label="{4|A|N|I}"];
  altura3 [label="{3|M|E|F}"];
  altura2 [label="{2|O|I|A}"];
  altura1 [label="{1|H|T|Z}"];
  header -> altura5 -> altura4 -> altura3 -> altura2 -> altura1;
}
