  altura9 [label="{9|Y|P|U|J|I|H}"];
  altura8 [label="{8|T|O|N|G|F|E}"];
  altura7 [label="{7|S|N|M|D|C|B}"];
  altura6 [label="{6|R|L|J|Z|A|Y}"];
  altura5 [label="{5|O|K|I|X|W|V}"];
  altura4 [label="{4|N|G|H|U|T|S}"];
  altura3 [label="{3|E|F|G|R|Q|P}"];
  altura2 [label="{2|D|C|F|O|N|M}"];
