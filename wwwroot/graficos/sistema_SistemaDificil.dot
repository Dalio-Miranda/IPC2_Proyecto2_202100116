digraph SistemaDrones {
  rankdir=TB;
  node [shape=record, style=filled, fillcolor="#1f2937", fontcolor="white", fontname="Arial", color="#374151"];
  graph [bgcolor="#111827", fontcolor="white", fontname="Arial"];
